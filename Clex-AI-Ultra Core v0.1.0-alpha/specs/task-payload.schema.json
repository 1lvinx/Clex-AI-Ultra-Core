{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Payload",
  "type": "object",
  "required": ["id", "type", "prompt", "inputs", "status"],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string"},
    "priority": {
      "type": "string",
      "enum": ["urgent", "high", "normal", "low"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "cancelled"]
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "prompt": {"type": "string"},
    "inputs": {"type": "object"},
    "outputs": {"type": "object"},
    "metadata": {
      "type": "object",
      "properties": {
        "agent": {"type": "string"},
        "startTime": {"type": "string", "format": "date-time"},
        "durationMs": {"type": "number"}
      }
    }
  }
}
