{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Manifest",
  "type": "object",
  "required": ["name", "version", "description", "capabilityGroup", "commands"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "object",
      "properties": {
        "en": {"type": "string"},
        "zh": {"type": "string"}
      },
      "required": ["en", "zh"]
    },
    "capabilityGroup": {
      "type": "string",
      "enum": ["G1", "G2", "G3", "G4", "G5", "G6"]
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {"$ref": "#/definitions/Command"}
    },
    "inputs": {"$ref": "#/definitions/ParamSchema"},
    "outputs": {"$ref": "#/definitions/ParamSchema"},
    "requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "runtimeTarget": {
      "type": "object",
      "properties": {
        "python": {"type": "string"},
        "nodejs": {"type": "string"},
        "go": {"type": "string"},
        "rust": {"type": "string"}
      }
    }
  },
  "definitions": {
    "Command": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {"type": "string"},
        "description": {
          "type": "object",
          "properties": {
            "en": {"type": "string"},
            "zh": {"type": "string"}
          },
          "required": ["en", "zh"]
        },
        "params": {"$ref": "#/definitions/ParamSchema"},
        "returns": {"$ref": "#/definitions/ParamSchema"}
      }
    },
    "ParamSchema": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["object", "string", "number", "array", "boolean"]},
        "properties": {"type": "object"}
      }
    }
  }
}
