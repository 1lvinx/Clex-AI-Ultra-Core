{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Permission Rule",
  "type": "object",
  "required": ["id", "scope", "matcherType", "resource", "effect"],
  "properties": {
    "id": {"type": "string"},
    "scope": {
      "type": "string",
      "enum": ["command", "file", "network", "agent", "mcp", "workflow"]
    },
    "matcherType": {
      "type": "string",
      "enum": ["exact", "prefix", "suffix", "regex", "glob"]
    },
    "resource": {"type": "string"},
    "effect": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "priority": {
      "type": "number",
      "minimum": 1
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "description": {
      "type": "object",
      "properties": {
        "en": {"type": "string"},
        "zh": {"type": "string"}
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": {"type": "string", "format": "date-time"},
        "modifiedAt": {"type": "string", "format": "date-time"},
        "userId": {"type": "string"}
      }
    }
  }
}
